ANTHROPIC_API_KEY=sk-ant-...

# Optional: separate key for experiment runs (to isolate cost tracking).
# If set, subprime experiment-run uses this key instead of ANTHROPIC_API_KEY.
ANTHROPIC_API_KEY_EXPERIMENT=sk-ant-...

# Together AI — needed for together:Qwen/... and together:google/gemma-* models.
TOGETHER_API_KEY=tgp_v1_...

# Web advisor model config.
# ADVISOR_MODEL: junior advisor that drafts the plan (default: haiku, cheap).
# REFINE_MODEL:  senior reviewer that polishes the draft (default: sonnet).
#                Set to "none" to skip the review pass entirely.
ADVISOR_MODEL=anthropic:claude-haiku-4-5
REFINE_MODEL=anthropic:claude-sonnet-4-6
